generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  name          String?
  password      String
  tier          String   @default("free")   // free | pro | premium
  onboarded     Boolean  @default(false)
  goalType      String?  // lose | maintain | gain
  activityLevel String?  // sedentary | light | moderate | active
  calorieGoal   Int      @default(1800)
  createdAt     DateTime @default(now())
  logs          FoodLog[]
  weightLogs    WeightLog[]
  waterLogs     WaterLog[]
  progressPhotos ProgressPhoto[]
  stepLogs      StepLog[]
  chatMessages  ChatMessage[]
  favoriteMeals FavoriteMeal[]
  habits        Habit[]
}

model FoodLog {
  id          Int      @id @default(autoincrement())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      Int
  meal        String
  calories    Int
  protein     Int
  carbs       Int
  fat         Int
  loggedAt    DateTime @default(now())
  imageUrl    String?

  @@index([userId, loggedAt])
}

model WeightLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  weight    Float
  unit      String   @default("lbs")
  loggedAt  DateTime @default(now())

  @@index([userId, loggedAt])
}

model WaterLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  glasses   Int
  loggedAt  DateTime @default(now())

  @@index([userId, loggedAt])
}

model ProgressPhoto {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  imageUrl  String
  note      String?
  loggedAt  DateTime @default(now())

  @@index([userId, loggedAt])
}

model StepLog {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  steps     Int
  loggedAt  DateTime @default(now())

  @@index([userId, loggedAt])
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  role      String   // 'user' | 'coach'
  text      String
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model FavoriteMeal {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  meal      String
  calories  Int
  protein   Int
  carbs     Int
  fat       Int
  createdAt DateTime @default(now())

  @@index([userId])
}

model Habit {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    Int
  title     String
  source    String   // 'daily' | 'weekly' | 'monthly' | 'custom' | 'coach'
  completed Boolean  @default(false)
  period    String   @default("") // 'YYYY-MM-DD' | 'YYYY-WXX' | 'YYYY-MM' | ''
  createdAt DateTime @default(now())

  @@index([userId, period])
}